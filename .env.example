UNPAYWALL_EMAIL=you@example.com

# Optional API keys
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_API_KEY=
CORE_API_KEY=

# Optional source switches
OPENALEX_ENABLED=true
CROSSREF_ENABLED=true
SEMANTIC_SCHOLAR_ENABLED=true
ARXIV_ENABLED=true
PUBMED_ENABLED=true
DOAJ_ENABLED=true
EUROPEPMC_ENABLED=true
CORE_ENABLED=false

# Optional base URL overrides
OPENALEX_BASE_URL=https://api.openalex.org
CROSSREF_BASE_URL=https://api.crossref.org
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org
ARXIV_BASE_URL=https://export.arxiv.org/api
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
DOAJ_BASE_URL=https://doaj.org/api
EUROPEPMC_BASE_URL=https://www.ebi.ac.uk/europepmc/webservices/rest
CORE_BASE_URL=https://api.core.ac.uk/v3/search/works
